config FREETZ_PACKAGE_RSYNC
	bool "rsync 3.4.1/3.4.3"
	select FREETZ_LIB_libpopt
	select FREETZ_LIB_libz
	default n
	help
		rsync is an open source utility that provides fast incremental
		file transfer.

if FREETZ_PACKAGE_RSYNC

	choice
		prompt "Version"
			default FREETZ_PACKAGE_RSYNC_VERSION_CURRENT

		config FREETZ_PACKAGE_RSYNC_VERSION_ABANDON
			bool "3.4.1 (AI free)"
#			depends on  (FREETZ_TARGET_UCLIBC_0_9_28 || FREETZ_TARGET_UCLIBC_0_9_29)

		config FREETZ_PACKAGE_RSYNC_VERSION_CURRENT
			bool "3.4.3 (AI slop)"
			depends on !(FREETZ_TARGET_UCLIBC_0_9_28 || FREETZ_TARGET_UCLIBC_0_9_29)

	endchoice

	config FREETZ_PACKAGE_RSYNC_REMOVE_WEBIF
		bool "remove webinterface"
		default n
		help
			This option removes the webinterface

endif # FREETZ_PACKAGE_RSYNC

