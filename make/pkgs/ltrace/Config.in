config FREETZ_PACKAGE_LTRACE
	bool "ltrace 0.7.3-git/0.8.1 (binary only)"
	default n
	depends on FREETZ_TARGET_GCC_4_7_MIN
	depends on !(FREETZ_TARGET_ARCH_ARM && FREETZ_TARGET_ARCH_BE && FREETZ_TARGET_BITS_32)  # no armeb, feel free to fix
	select FREETZ_LIB_libelf
	help
		ltrace - library call tracer

		ltrace is a debugging tool, similar to strace, but it traces library
		calls instead of system calls.

if FREETZ_PACKAGE_LTRACE

	choice
		prompt "Version"
			default FREETZ_PACKAGE_LTRACE_VERSION_CURRENT

		config FREETZ_PACKAGE_LTRACE_VERSION_ABANDON
			bool "0.7.3-git"
			depends on !(FREETZ_SEPARATE_AVM_UCLIBC && !FREETZ_KERNEL_VERSION_2)

		config FREETZ_PACKAGE_LTRACE_VERSION_CURRENT
			bool "0.8.1"
			depends on  (FREETZ_SEPARATE_AVM_UCLIBC && !FREETZ_KERNEL_VERSION_2)

	endchoice

endif # FREETZ_PACKAGE_LTRACE

