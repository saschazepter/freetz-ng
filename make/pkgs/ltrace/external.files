if [ "$EXTERNAL_FREETZ_PACKAGE_LTRACE" == "y" ]; then
	EXTERNAL_FILES+=" /usr/sbin/ltrace"
	EXTERNAL_FILES+=" /usr/share/ltrace/libacl.so.conf"
	EXTERNAL_FILES+=" /usr/share/ltrace/libc.so.conf"
	EXTERNAL_FILES+=" /usr/share/ltrace/libc.so-types.conf"
	EXTERNAL_FILES+=" /usr/share/ltrace/libm.so.conf"
	EXTERNAL_FILES+=" /usr/share/ltrace/libpthread.so.conf"
	EXTERNAL_FILES+=" /usr/share/ltrace/libpthread.so-types.conf"
	EXTERNAL_FILES+=" /usr/share/ltrace/syscalls.conf"
fi

